{
  "name": "@sveltia/ui",
  "version": "0.37.1",
  "description": "A collection of Svelte components and utilities for building user interfaces.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sveltia/sveltia-ui.git"
  },
  "license": "MIT",
  "author": {
    "name": "Kohei Yoshino",
    "url": "https://github.com/kyoshino"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "svelte": "./dist/index.js",
  "typesVersions": {
    ">4.0": {
      "index": [
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "svelte-kit sync && svelte-package",
    "build:watch": "svelte-kit sync && svelte-package --watch",
    "check": "pnpm run '/^check:.*/'",
    "check:audit": "pnpm audit",
    "check:cspell": "cspell --no-progress",
    "check:eslint": "eslint .",
    "check:oxlint": "oxlint .",
    "check:prettier": "prettier --check .",
    "check:stylelint": "stylelint '**/*.{css,scss,svelte}'",
    "check:svelte": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "dev": "vite dev",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lexical/code": "^0.43.0",
    "@lexical/code-prism": "^0.43.0",
    "@lexical/dragon": "^0.43.0",
    "@lexical/extension": "^0.43.0",
    "@lexical/history": "^0.43.0",
    "@lexical/link": "^0.43.0",
    "@lexical/list": "^0.43.0",
    "@lexical/markdown": "^0.43.0",
    "@lexical/rich-text": "^0.43.0",
    "@lexical/selection": "^0.43.0",
    "@lexical/table": "^0.43.0",
    "@lexical/utils": "^0.43.0",
    "@sveltia/i18n": "^1.0.2",
    "@sveltia/utils": "^0.10.0",
    "lexical": "^0.43.0",
    "prismjs": "^1.30.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "cspell": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "oxlint": "^1.59.0",
    "postcss": "^8.5.9",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sass": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-scss": "^7.0.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.8.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
